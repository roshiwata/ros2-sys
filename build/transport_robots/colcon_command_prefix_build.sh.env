AMENT_PREFIX_PATH=/opt/ros/humble
COLCON=1
DISPLAY=:1
HOME=/root
HOSTNAME=tatsu-g15-ubuntu
LANG=C.UTF-8
LC_ALL=C.UTF-8
LD_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/gazebo-11/plugins:/opt/ros/humble/opt/rviz_ogre_vendor/lib:/opt/ros/humble/lib/x86_64-linux-gnu:/opt/ros/humble/lib
LIBGL_ALWAYS_INDIRECT=0
NVIDIA_DRIVER_CAPABILITIES=all
NVIDIA_VISIBLE_DEVICES=all
OLDPWD=/workspace
PATH=/opt/ros/humble/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
PWD=/workspace/build/transport_robots
PYTHONPATH=/opt/ros/humble/lib/python3.10/site-packages:/opt/ros/humble/local/lib/python3.10/dist-packages
QT_X11_NO_MITSHM=1
RMW_IMPLEMENTATION=rmw_fastrtps_cpp
ROS_DISTRO=humble
ROS_DOMAIN_ID=0
ROS_LOCALHOST_ONLY=0
ROS_PYTHON_VERSION=3
ROS_VERSION=2
SHLVL=0
TERM=xterm
XAUTHORITY=/tmp/.docker.xauth
_=/usr/bin/colcon
